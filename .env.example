GROQ_API_KEY=your_groq_api_key
GOOGLE_API_KEY=your_gemini_key_as_backup
CHROMA_PERSIST_DIR=./chroma_db
GROQ_MODEL=llama-3.3-70b-versatile

# Audit (§ 2.2.2): tamper-evident logs, 6-year retention
AUDIT_LOG_DIR=./audit_logs
AUDIT_RETENTION_YEARS=6

# Jira (optional; can also be entered in UI)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_atlassian_api_token

# Role → assignee (accountId for JIRA Cloud). Auto-assign tasks by responsible_role.
JIRA_ASSIGNEE_BACKEND_ENGINEER=557058:xxx-xxx-xxx
JIRA_ASSIGNEE_FRONTEND_ENGINEER=557058:yyy-yyy-yyy
JIRA_ASSIGNEE_DEVOPS=557058:zzz-zzz-zzz
JIRA_ASSIGNEE_SECURITY=557058:aaa-aaa-aaa

# Sprint field (default customfield_10020 for JIRA Cloud)
# JIRA_SPRINT_FIELD_ID=customfield_10020

# GitHub (optional; for prepopulating export UI)
# GITHUB_REPO=owner/repo
# GITHUB_TOKEN=your_github_personal_access_token
